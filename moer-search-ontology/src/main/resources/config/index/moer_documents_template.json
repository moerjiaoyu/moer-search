{
  "index_patterns": ["moer_documents_*"],
  "template": {
    "settings": {
      "number_of_shards": 3,
      "number_of_replicas": 1,
      "index.lifecycle.name": "ontology_policy",
      "index.lifecycle.rollover_alias": "moer_documents"
    },
    "mappings": {
      "properties": {
        "title": {
          "type": "text",
          "analyzer": "ik_smart",
          "search_analyzer": "ik_max_word"
        },
        "content": {
          "type": "text",
          "analyzer": "ik_smart",
          "search_analyzer": "ik_max_word"
        },
        "concept_tags": {
          "type": "keyword"
        },
        "semantic_types": {
          "type": "keyword"
        },
        "instance_id": {
          "type": "keyword"
        },
        "concept_id": {
          "type": "keyword"
        },
        "concept_name": {
          "type": "text",
          "analyzer": "ik_smart"
        },
        "create_time": {
          "type": "date",
          "format": "epoch_millis"
        },
        "update_time": {
          "type": "date",
          "format": "epoch_millis"
        },
        "is_active": {
          "type": "boolean"
        }
      }
    }
  },
  "priority": 500
}